/**app.wxss**/
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

button {
  background: initial;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

page {
  background: #f7f8fa;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.auth-gate,
.feedback-panel {
  position: relative;
  overflow: hidden;
  background: #FFFFFF;
  border-radius: 10rpx;
  box-shadow: 0 14rpx 30rpx rgba(11, 11, 11, 0.05);
}

.auth-gate {
  padding: 0;
}

.auth-gate::before,
.feedback-panel::before {
  display: none;
}

.auth-gate__hero {
  padding: 32rpx 32rpx 12rpx;
  background: #FFFFFF;
}

.auth-gate__eyebrow {
  font-size: 22rpx;
  line-height: 1.4;
  letter-spacing: 4rpx;
  color: #6B7280;
  font-weight: 600;
}

.auth-gate__title {
  margin-top: 10rpx;
  font-size: 34rpx;
  line-height: 1.45;
  font-weight: 600;
  color: #0B0B0B;
}

.auth-gate__text {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #6B7280;
}

.auth-gate__body {
  padding: 0 32rpx 32rpx;
}

.auth-gate__surface {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: inset 0 0 0 1rpx rgba(15, 23, 42, 0.05);
}

.auth-gate__button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 28rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0B0B0B 0%, #2A2A2A 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 18rpx 36rpx rgba(11, 11, 11, 0.18);
}

.feedback-panel {
  padding: 84rpx 42rpx;
  text-align: center;
  background: #FFFFFF;
}

.feedback-panel__eyebrow {
  font-size: 22rpx;
  line-height: 1.4;
  letter-spacing: 4rpx;
  color: #6B7280;
  font-weight: 600;
}

.feedback-panel__title {
  margin-top: 10rpx;
  font-size: 34rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #0B0B0B;
}

.feedback-panel__text {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: #6B7280;
}

.feedback-panel__button {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  min-width: 220rpx;
  margin-top: 34rpx;
  padding: 22rpx 34rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0B0B0B 0%, #2A2A2A 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 18rpx 36rpx rgba(11, 11, 11, 0.14);
}
