/**app.wxss**/
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
} 

button {
  background: initial;
}

button:focus{
  outline: 0;
}

button::after{
  border: none;
}


page {
  background: #f7f8fa;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.auth-gate,
.feedback-panel {
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.05);
}

.auth-gate {
  padding: 34rpx 30rpx;
}

.auth-gate__eyebrow {
  font-size: 22rpx;
  line-height: 1.4;
  letter-spacing: 4rpx;
  color: #9ca3af;
}

.auth-gate__title {
  margin-top: 12rpx;
  font-size: 34rpx;
  line-height: 1.45;
  font-weight: 600;
  color: #111827;
}

.auth-gate__text {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #6b7280;
}

.auth-gate__button {
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 1.2;
  padding: 0 28rpx;
}

.feedback-panel {
  padding: 90rpx 36rpx;
  text-align: center;
}

.feedback-panel__title {
  font-size: 34rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #111827;
}

.feedback-panel__text {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: #6b7280;
}

.feedback-panel__button {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  min-width: 220rpx;
  margin-top: 28rpx;
  padding: 20rpx 28rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
  font-size: 26rpx;
}
