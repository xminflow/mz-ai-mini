page {
  background: #f7f8fa;
  color: #0B0B0B;
}

.tab-page {
  padding: 24rpx 20rpx 56rpx;
}

.tab-hero,
.info-card {
  background: #FFFFFF;
  border-radius: 10rpx;
  box-shadow: 0 14rpx 30rpx rgba(11, 11, 11, 0.05);
}

.tab-hero {
  padding: 24rpx;
}

.tab-hero__eyebrow {
  font-size: 22rpx;
  line-height: 1.4;
  letter-spacing: 4rpx;
  color: #6B7280;
}

.tab-hero__title {
  margin-top: 10rpx;
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 600;
}

.tab-hero__text {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #6B7280;
}

.tab-section {
  margin-top: 20rpx;
}

.tab-section__title {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #6B7280;
}

.info-card {
  padding: 22rpx 20rpx;
}

.info-card--loading {
  margin-top: 20rpx;
  opacity: 0.82;
}

.info-card__title {
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 500;
  color: #1F1F1F;
}

.info-card__text {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.8;
  color: #6B7280;
}

.membership-card {
  margin-top: 16rpx;
  padding: 22rpx 20rpx;
  background: #FFFFFF;
  border-radius: 10rpx;
  box-shadow: 0 14rpx 30rpx rgba(11, 11, 11, 0.05);
}

.membership-card--disabled {
  opacity: 0.78;
}

.membership-card__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 20rpx;
}

.membership-card__title {
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #0B0B0B;
}

.membership-card__price {
  font-size: 24rpx;
  line-height: 1.5;
  color: #6B7280;
}

.membership-card__text {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.8;
  color: #6B7280;
}

.membership-card__button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
  line-height: 80rpx;
  margin-top: 18rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #0B0B0B;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
}

.membership-card__button[disabled],
.membership-card__button--disabled {
  background: #E5E7EB;
  color: #6B7280;
  box-shadow: none;
}
