page {
  background: #f7f8fa;
  color: #111827;
}

.tab-page {
  padding: 24rpx 20rpx 56rpx;
}

.tab-hero,
.info-card {
  background: #ffffff;
  border-radius: 10rpx;
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.05);
}

.tab-hero {
  padding: 24rpx;
}

.tab-hero__eyebrow {
  font-size: 22rpx;
  line-height: 1.4;
  letter-spacing: 4rpx;
  color: #9ca3af;
}

.tab-hero__title {
  margin-top: 10rpx;
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 600;
}

.tab-hero__text {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #6b7280;
}

.tab-section {
  margin-top: 20rpx;
}

.tab-section__title {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #6b7280;
}

.info-card {
  padding: 22rpx 20rpx;
}

.info-card--loading {
  margin-top: 20rpx;
  opacity: 0.82;
}

.info-card__title {
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 500;
  color: #1f2937;
}

.info-card__text {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.8;
  color: #7b8794;
}

.membership-card {
  margin-top: 16rpx;
  padding: 22rpx 20rpx;
  background: #ffffff;
  border-radius: 10rpx;
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.05);
}

.membership-card--disabled {
  opacity: 0.78;
}

.membership-card__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 20rpx;
}

.membership-card__title {
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #111827;
}

.membership-card__price {
  font-size: 24rpx;
  line-height: 1.5;
  color: #4b5563;
}

.membership-card__text {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.8;
  color: #7b8794;
}

.membership-card__button {
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.2;
  padding: 0 24rpx;
}

.membership-card__button[disabled],
.membership-card__button--disabled {
  background: #e5e7eb;
  color: #9ca3af;
}
