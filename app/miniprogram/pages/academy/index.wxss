page {
  background: #f7f8fa;
  color: #111827;
}

.tab-page {
  padding: 24rpx 20rpx 56rpx;
}

.tab-hero {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 10rpx;
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.05);
}

.tab-hero__eyebrow {
  font-size: 22rpx;
  line-height: 1.4;
  letter-spacing: 4rpx;
  color: #9ca3af;
}

.tab-hero__title {
  margin-top: 10rpx;
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 600;
}

.tab-hero__text {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #6b7280;
}

.card-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.academy-card {
  padding: 22rpx 20rpx;
  background: #ffffff;
  border-radius: 10rpx;
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.05);
}

.academy-card__label {
  font-size: 20rpx;
  line-height: 1.4;
  color: #94a3b8;
}

.academy-card__title {
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 500;
  color: #1f2937;
}

.academy-card__text {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.8;
  color: #7b8794;
}
