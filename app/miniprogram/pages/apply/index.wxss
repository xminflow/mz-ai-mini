page {
  background: #f7f8fa;
  color: #0B0B0B;
}

.tab-page {
  padding: 24rpx 20rpx 56rpx;
}

.info-card,
.form-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 14rpx 30rpx rgba(11, 11, 11, 0.05);
}

.info-card {
  padding: 22rpx 20rpx;
}

.info-card--loading {
  margin-top: 20rpx;
  opacity: 0.82;
}

.info-card__title {
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 500;
  color: #1F1F1F;
}

.info-card__text {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.8;
  color: #6B7280;
}

/* Auth gate */
.auth-gate {
  margin-top: 20rpx;
  padding: 32rpx 28rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 14rpx 30rpx rgba(11, 11, 11, 0.05);
}

.auth-gate__eyebrow {
  font-size: 22rpx;
  line-height: 1.4;
  letter-spacing: 4rpx;
  color: #6B7280;
}

.auth-gate__title {
  margin-top: 10rpx;
  font-size: 34rpx;
  line-height: 1.45;
  font-weight: 600;
  color: #0B0B0B;
}

.auth-gate__text {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #6B7280;
}

.auth-gate__body {
  margin-top: 28rpx;
}

.auth-gate__button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #0B0B0B;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
}

/* Feedback panel */
.feedback-panel {
  margin-top: 20rpx;
  padding: 32rpx 28rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 14rpx 30rpx rgba(11, 11, 11, 0.05);
}

.feedback-panel__eyebrow {
  font-size: 22rpx;
  line-height: 1.4;
  letter-spacing: 4rpx;
  color: #6B7280;
}

.feedback-panel__title {
  margin-top: 8rpx;
  font-size: 34rpx;
  line-height: 1.45;
  font-weight: 600;
  color: #0B0B0B;
}

.feedback-panel__text {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #6B7280;
}

.feedback-panel__button {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 28rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: #0B0B0B;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
}

/* Form section */
.form-section {
  margin-top: 20rpx;
}

.apply-banner {
  display: block;
  width: 100%;
  border-radius: 16rpx;
  background: #F3F4F6;
}

.form-card {
  margin-top: 16rpx;
  padding: 24rpx 20rpx;
}

.form-card__title {
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #0B0B0B;
}

/* Form fields */
.form-field {
  margin-top: 20rpx;
}

.form-field__label {
  font-size: 24rpx;
  line-height: 1.5;
  color: #1F1F1F;
}

.form-field__control,
.picker-field,
.form-field__control--textarea {
  box-sizing: border-box;
  width: 100%;
  margin-top: 10rpx;
  background: #F8FAFC;
  border-radius: 14rpx;
}

.form-field__control {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 20rpx;
}

.form-field__control--textarea {
  padding: 20rpx;
}

.form-field__input,
.picker-field,
.form-field__textarea {
  font-size: 24rpx;
  color: #111827;
}

.form-field__input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
}

.picker-field {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 20rpx;
}

.picker-field__text {
  width: 100%;
  line-height: 1.6;
}

.form-field__textarea {
  display: block;
  width: 100%;
  min-height: 220rpx;
  line-height: 1.7;
}

/* Type selector */
.type-selector {
  display: flex;
  gap: 12rpx;
  margin-top: 10rpx;
}

.type-selector__option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 20rpx 12rpx;
  background: #F8FAFC;
  border-radius: 14rpx;
  border: 2rpx solid transparent;
}

.type-selector__option--active {
  background: #F0F9FF;
  border-color: #0B0B0B;
}

.type-selector__name {
  font-size: 26rpx;
  line-height: 1.4;
  font-weight: 500;
  color: #1F1F1F;
}

.type-selector__tag {
  font-size: 22rpx;
  line-height: 1.4;
  color: #6B7280;
}

.type-selector__option--active .type-selector__name {
  color: #0B0B0B;
}

.type-selector__option--active .type-selector__tag {
  color: #374151;
}

.type-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.8;
  color: #6B7280;
}

/* Submit button */
.form-card__button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 28rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #0B0B0B;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
}

.form-card__button[disabled] {
  background: #E5E7EB;
  color: #6B7280;
}
