page {
  background: #f7f8fa;
  color: #0B0B0B;
}

.tab-page {
  padding: 24rpx 20rpx 56rpx;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 20rpx;
  background: #FFFFFF;
  border-radius: 10rpx;
  box-shadow: 0 14rpx 30rpx rgba(11, 11, 11, 0.05);
}

.profile-card__avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.profile-card__content {
  min-width: 0;
}

.profile-card__name {
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 500;
  color: #1F1F1F;
}

.profile-card__badge {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6B7280;
}

.profile-card--loading {
  opacity: 0.82;
}

.auth-gate {
  padding: 32rpx 28rpx;
  background: #FFFFFF;
  border-radius: 10rpx;
  box-shadow: 0 14rpx 30rpx rgba(11, 11, 11, 0.05);
}

.auth-gate__title {
  font-size: 34rpx;
  line-height: 1.45;
  font-weight: 600;
  color: #0B0B0B;
}

.auth-gate__text {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #6B7280;
}

.auth-gate__body {
  margin-top: 28rpx;
}

.profile-editor {
  margin-top: 18rpx;
}

.profile-editor__row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  padding: 18rpx 0;
  background: #FFFFFF;
  border-bottom: 2rpx solid #F3F4F6;
  box-sizing: border-box;
}

.profile-editor__row:last-of-type {
  border-bottom: 0;
}

.profile-editor__row--button {
  padding-right: 0;
}

.profile-editor__row--button::after {
  border: 0;
}

.profile-editor__meta {
  min-width: 96rpx;
  flex-shrink: 0;
}

.profile-editor__label {
  font-size: 26rpx;
  line-height: 1.5;
  color: #111827;
}

.profile-editor__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 999rpx;
  background: #E5E7EB;
  flex-shrink: 0;
}

.profile-editor__input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  padding: 0;
  background: transparent;
  border: 0;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #111827;
  text-align: right;
}

.profile-editor__status {
  margin-left: auto;
  font-size: 22rpx;
  line-height: 1.5;
  color: #9CA3AF;
}

.section-label {
  margin-top: 32rpx;
  margin-bottom: 16rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #6B7280;
}

.membership-card {
  padding: 22rpx 20rpx;
  background: #FFFFFF;
  border-radius: 10rpx;
  box-shadow: 0 14rpx 30rpx rgba(11, 11, 11, 0.05);
}

.membership-card + .membership-card {
  margin-top: 16rpx;
}

.membership-card--locked {
  opacity: 0.5;
}

.membership-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.membership-card__title {
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #0B0B0B;
}

.membership-card__price {
  font-size: 22rpx;
  line-height: 1.5;
  color: #6B7280;
  flex-shrink: 0;
}

.membership-card__active-badge {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1.5;
  color: #0B0B0B;
  background: #E5E7EB;
  padding: 4rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

.membership-card__action {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1.5;
  color: #0B0B0B;
  background: #F3F4F6;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
}

.membership-card__text {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.8;
  color: #6B7280;
}

.membership-card__button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
  line-height: 80rpx;
  margin-top: 20rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #0B0B0B;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
}

.auth-gate__button {
  margin-top: 18rpx;
}

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.menu-item {
  padding: 22rpx 20rpx;
  background: #FFFFFF;
  border-radius: 10rpx;
  box-shadow: 0 14rpx 30rpx rgba(11, 11, 11, 0.05);
}

.menu-item__title {
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 500;
  color: #1F1F1F;
}

.menu-item__text {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.8;
  color: #6B7280;
}
