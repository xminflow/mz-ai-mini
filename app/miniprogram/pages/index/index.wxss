page {
  background: #f7f8fa;
  color: #0B0B0B;
}

.page-shell {
  padding: 24rpx 20rpx 56rpx;
}

.page-banner {
  overflow: hidden;
  border-radius: 10rpx;
  background: #FFFFFF;
  box-shadow: 0 14rpx 32rpx rgba(11, 11, 11, 0.06);
}

.page-banner__swiper {
  width: 100%;
  height: 400rpx;
}

.page-banner__image {
  width: 100%;
  height: 400rpx;
  display: block;
}

.story-search {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  background: #FFFFFF;
  border-radius: 10rpx;
  box-shadow: 0 14rpx 32rpx rgba(11, 11, 11, 0.06);
}

.story-search__input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #f7f8fa;
  font-size: 26rpx;
}

.story-search__action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  min-width: 136rpx;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #0B0B0B;
  color: #FFFFFF;
  font-size: 24rpx;
}

.story-tabs {
  margin-top: 18rpx;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border-radius: 10rpx;
  box-shadow: 0 14rpx 32rpx rgba(11, 11, 11, 0.06);
}

.story-tabs__list {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
  min-width: 100%;
}

.story-tabs__item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(11, 11, 11, 0.1);
  background: #FFFFFF;
  color: #6B7280;
  font-size: 24rpx;
  line-height: 1.4;
}

.story-tabs__item--active {
  border-color: #0B0B0B;
  background: #0B0B0B;
  color: #FFFFFF;
  box-shadow: 0 12rpx 24rpx rgba(11, 11, 11, 0.16);
}

.industry-sheet__mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  background: rgba(11, 11, 11, 0.46);
  display: flex;
  align-items: flex-end;
}

.industry-sheet {
  width: 100%;
  padding: 28rpx 24rpx 40rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: #FFFFFF;
}

.industry-sheet__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.industry-sheet__title {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.5;
}

.industry-sheet__close {
  font-size: 24rpx;
  line-height: 1.4;
  color: #6B7280;
}

.industry-sheet__list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.industry-sheet__item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 160rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(11, 11, 11, 0.1);
  background: #FFFFFF;
  color: #4B5563;
  font-size: 24rpx;
  line-height: 1.4;
}

.industry-sheet__item--active {
  border-color: #0B0B0B;
  background: #0B0B0B;
  color: #FFFFFF;
  box-shadow: 0 12rpx 24rpx rgba(11, 11, 11, 0.16);
}

.feed-grid {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  margin-top: 24rpx;
}

.feed-column {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.skeleton-card {
  padding: 18rpx;
  background: #FFFFFF;
  border-radius: 8rpx;
  box-shadow:
    0 10rpx 20rpx rgba(11, 11, 11, 0.04),
    0 24rpx 44rpx rgba(11, 11, 11, 0.08);
}

.skeleton-card__cover {
  height: 228rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #E5E7EB 25%, #f7f8fa 50%, #E5E7EB 75%);
}

.skeleton-card__line {
  height: 22rpx;
  border-radius: 6rpx;
  background: #E5E7EB;
  margin-top: 16rpx;
}

.skeleton-card__line--title {
  width: 82%;
  height: 28rpx;
  margin-top: 22rpx;
}

.skeleton-card__line--short {
  width: 58%;
}

.feedback {
  margin-top: 24rpx;
  padding: 72rpx 34rpx;
  border-radius: 10rpx;
  background: #FFFFFF;
  box-shadow: 0 14rpx 30rpx rgba(11, 11, 11, 0.05);
}

.feedback--center {
  text-align: center;
}

.feedback__title {
  font-size: 34rpx;
  line-height: 1.5;
  font-weight: 600;
}

.feedback__text {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: #6B7280;
}

.feedback__button {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  min-width: 220rpx;
  margin-top: 28rpx;
  padding: 20rpx 28rpx;
  border-radius: 8rpx;
  background: #0B0B0B;
  color: #FFFFFF;
  font-size: 26rpx;
}

.feed-footer {
  padding: 28rpx 0 12rpx;
  text-align: center;
}

.feed-footer__text,
.feed-footer__action {
  font-size: 24rpx;
  line-height: 1.6;
  color: #6B7280;
}

.feed-footer__action {
  color: #1F1F1F;
}
