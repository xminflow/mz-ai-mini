page {
  background: #f7f8fa;
  color: #111827;
}

.page-shell {
  padding: 24rpx 20rpx 56rpx;
}

.page-banner {
  overflow: hidden;
  border-radius: 10rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.06);
}

.page-banner__swiper {
  width: 100%;
  height: 400rpx;
}

.page-banner__image {
  width: 100%;
  height: 400rpx;
  display: block;
}

.story-tabs {
  margin-top: 18rpx;
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-radius: 10rpx;
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.06);
}

.story-tabs__list {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
  min-width: 100%;
}

.story-tabs__item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  background: #ffffff;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.4;
}

.story-tabs__item--active {
  border-color: #111827;
  background: #111827;
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.16);
}

.feed-grid {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  margin-top: 24rpx;
}

.feed-column {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.skeleton-card {
  padding: 18rpx;
  background: #ffffff;
  border-radius: 8rpx;
  box-shadow:
    0 10rpx 20rpx rgba(15, 23, 42, 0.04),
    0 24rpx 44rpx rgba(15, 23, 42, 0.08);
}

.skeleton-card__cover {
  height: 228rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #e5e7eb 25%, #f7f8fa 50%, #e5e7eb 75%);
}

.skeleton-card__line {
  height: 22rpx;
  border-radius: 6rpx;
  background: #e5e7eb;
  margin-top: 16rpx;
}

.skeleton-card__line--title {
  width: 82%;
  height: 28rpx;
  margin-top: 22rpx;
}

.skeleton-card__line--short {
  width: 58%;
}

.feedback {
  margin-top: 24rpx;
  padding: 72rpx 34rpx;
  border-radius: 10rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.05);
}

.feedback--center {
  text-align: center;
}

.feedback__title {
  font-size: 34rpx;
  line-height: 1.5;
  font-weight: 600;
}

.feedback__text {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: #6b7280;
}

.feedback__button {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  min-width: 220rpx;
  margin-top: 28rpx;
  padding: 20rpx 28rpx;
  border-radius: 8rpx;
  background: #111827;
  color: #ffffff;
  font-size: 26rpx;
}

.feed-footer {
  padding: 28rpx 0 12rpx;
  text-align: center;
}

.feed-footer__text,
.feed-footer__action {
  font-size: 24rpx;
  line-height: 1.6;
  color: #9ca3af;
}

.feed-footer__action {
  color: #374151;
}
