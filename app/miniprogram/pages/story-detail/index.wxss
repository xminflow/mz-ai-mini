page {
  background: #f7f8fa;
  color: #0B0B0B;
}

.detail-page {
  padding: 30rpx 28rpx 60rpx;
}

.detail-skeleton,
.detail-feedback,
.detail-article {
  background: #FFFFFF;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 30rpx rgba(11, 11, 11, 0.05);
}

.detail-skeleton {
  padding: 24rpx;
}

.detail-skeleton__cover {
  height: 420rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #E5E7EB 25%, #f7f8fa 50%, #E5E7EB 75%);
}

.detail-skeleton__line {
  height: 24rpx;
  border-radius: 6rpx;
  background: #E5E7EB;
  margin-top: 18rpx;
}

.detail-skeleton__line--title {
  width: 84%;
  height: 32rpx;
  margin-top: 28rpx;
}

.detail-skeleton__line--short {
  width: 56%;
}

.detail-feedback {
  padding: 90rpx 36rpx;
  text-align: center;
}

.detail-feedback__title {
  margin-top: 12rpx;
  font-size: 34rpx;
  line-height: 1.5;
  font-weight: 600;
}

.detail-feedback__text {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: #6B7280;
}

.detail-feedback__button {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  min-width: 220rpx;
  margin-top: 28rpx;
  padding: 20rpx 28rpx;
  border-radius: 8rpx;
  background: #0B0B0B;
  color: #FFFFFF;
  font-size: 26rpx;
}

.detail-article__cover {
  width: 100%;
  height: 420rpx;
  display: block;
  background: #E5E7EB;
}

.detail-article__head {
  padding: 34rpx 30rpx 26rpx;
}

.detail-article__title {
  font-size: 44rpx;
  line-height: 1.42;
  font-weight: 600;
}

.detail-article__summary {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.86;
  color: #6B7280;
}

.detail-article__tags {
  margin-top: 24rpx;
}

.detail-article__result {
  margin-top: 26rpx;
  padding: 20rpx 22rpx;
  border-radius: 8rpx;
  background: #f8fafc;
  color: #6B7280;
  font-size: 26rpx;
  line-height: 1.7;
}

.detail-article__content {
  padding: 8rpx 30rpx 40rpx;
}

.detail-tabs {
  display: flex;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

.detail-tabs__item {
  flex: 1;
  min-width: 0;
  padding: 18rpx 20rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6B7280;
  font-size: 24rpx;
  line-height: 1.5;
  text-align: center;
}

.detail-tabs__item--active {
  background: #0B0B0B;
  color: #FFFFFF;
}

.detail-section {
  margin-top: 34rpx;
}

.detail-section:first-child {
  margin-top: 0;
}
