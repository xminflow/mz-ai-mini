page {
  background: #f7f8fa;
  color: #0B0B0B;
}

.detail-page {
  padding: 30rpx 28rpx 160rpx;
}

.detail-skeleton,
.detail-feedback,
.detail-article {
  background: #FFFFFF;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 30rpx rgba(11, 11, 11, 0.05);
}

.detail-skeleton {
  padding: 24rpx;
}

.detail-skeleton__cover {
  height: 420rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #E5E7EB 25%, #f7f8fa 50%, #E5E7EB 75%);
}

.detail-skeleton__line {
  height: 24rpx;
  border-radius: 6rpx;
  background: #E5E7EB;
  margin-top: 18rpx;
}

.detail-skeleton__line--title {
  width: 84%;
  height: 32rpx;
  margin-top: 28rpx;
}

.detail-skeleton__line--short {
  width: 56%;
}

.detail-feedback {
  padding: 90rpx 36rpx;
  text-align: center;
}

.detail-feedback__title {
  margin-top: 12rpx;
  font-size: 34rpx;
  line-height: 1.5;
  font-weight: 600;
}

.detail-feedback__text {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: #6B7280;
}

.detail-feedback__button {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  min-width: 220rpx;
  margin-top: 28rpx;
  padding: 20rpx 28rpx;
  border-radius: 8rpx;
  background: #0B0B0B;
  color: #FFFFFF;
  font-size: 26rpx;
}

.detail-article__cover {
  width: 100%;
  height: 420rpx;
  display: block;
  background: #E5E7EB;
}

.detail-article__head {
  padding: 34rpx 30rpx 26rpx;
}

.detail-article__title {
  font-size: 44rpx;
  line-height: 1.42;
  font-weight: 600;
}

.detail-article__summary {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.86;
  color: #6B7280;
}

.detail-article__tags {
  margin-top: 24rpx;
}

.detail-article__result {
  margin-top: 26rpx;
  padding: 20rpx 22rpx;
  border-radius: 8rpx;
  background: #f8fafc;
  color: #6B7280;
  font-size: 26rpx;
  line-height: 1.7;
}

.detail-article__content {
  padding: 32rpx 30rpx 40rpx;
}

.detail-full-report-pin {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 16rpx 28rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 1rpx solid #F0F0F0;
}

.detail-full-report-pin__inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 22rpx 0;
  border-radius: 12rpx;
  background: #0B0B0B;
}

.detail-full-report-pin__label {
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.detail-full-report-pin__arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1;
}

.detail-section {
  margin-top: 0;
}

.detail-bottom-tabs {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  background: #FFFFFF;
  border-top: 1rpx solid #F0F0F0;
  padding-bottom: env(safe-area-inset-bottom);
}

.detail-bottom-tabs__item {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 8rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #9CA3AF;
}

.detail-bottom-tabs__item--active {
  color: #0B0B0B;
  font-weight: 600;
}

.detail-bottom-tabs__item--active::before {
  content: '';
  position: absolute;
  top: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: #0B0B0B;
  border-radius: 0 0 4rpx 4rpx;
}
