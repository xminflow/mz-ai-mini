<view class="detail-page">
  <view class="detail-skeleton" wx:if="{{authState === authPageState.CHECKING}}">
    <view class="detail-skeleton__cover"></view>
    <view class="detail-skeleton__line detail-skeleton__line--title"></view>
    <view class="detail-skeleton__line"></view>
    <view class="detail-skeleton__line detail-skeleton__line--short"></view>
  </view>

  <view class="auth-gate" wx:elif="{{authState === authPageState.UNAUTHORIZED}}">
    <view class="auth-gate__hero">
      <view class="auth-gate__eyebrow">案例解锁</view>
      <view class="auth-gate__title">完成微信登录后再阅读完整案例</view>
      <view class="auth-gate__text">
        当前还无法识别你的微信身份，请重新同步登录状态后再继续阅读。
      </view>
    </view>

    <view class="auth-gate__body">
      <button class="auth-gate__button" bindtap="handleAuthorize">前往我的页</button>
    </view>
  </view>

  <view class="detail-feedback" wx:elif="{{authState === authPageState.ERROR}}">
    <view class="feedback-panel__eyebrow">案例详情</view>
    <view class="detail-feedback__title">当前无法确认登录状态</view>
    <view class="detail-feedback__text">
      请检查后端服务是否可用，然后重新尝试。
    </view>
    <view class="detail-feedback__button" bindtap="handleRetry">重新检查</view>
  </view>

  <view class="detail-skeleton" wx:elif="{{isLoading}}">
    <view class="detail-skeleton__cover"></view>
    <view class="detail-skeleton__line detail-skeleton__line--title"></view>
    <view class="detail-skeleton__line"></view>
    <view class="detail-skeleton__line detail-skeleton__line--short"></view>
  </view>

  <view class="detail-feedback" wx:elif="{{loadError}}">
    <view class="feedback-panel__eyebrow">案例详情</view>
    <view class="detail-feedback__title">当前案例暂时无法打开</view>
    <view class="detail-feedback__text">
      请检查本地后端服务、数据库以及案例数据是否可用，然后重新尝试。
    </view>
    <view class="detail-feedback__button" bindtap="handleRetry">重新加载</view>
  </view>

  <view class="detail-article" wx:elif="{{story}}">
    <image class="detail-article__cover" wx:if="{{activeDocumentKey === 'summary' || !story.documentMap.summary}}" src="{{story.coverImage}}" mode="aspectFill" bindtap="handleCoverImageTap"></image>

    <view class="detail-article__head" wx:if="{{activeDocumentKey === 'summary' || !story.documentMap.summary}}">
      <view class="detail-article__title">{{story.title}}</view>
      <view class="detail-article__summary">{{story.summary}}</view>

      <view class="detail-article__tags" wx:if="{{story.tags.length}}">
        <story-tags tags="{{story.tags}}" size="md"></story-tags>
      </view>

      <view class="detail-article__result" wx:if="{{story.resultText}}">
        {{story.resultText}}
      </view>

    </view>

    <view class="detail-article__content">
      <view class="detail-section" wx:if="{{activeDocument}}">
        <markdown-renderer markdown="{{activeDocument.markdownContent}}"></markdown-renderer>
      </view>
    </view>
  </view>

  <view class="detail-full-report-pin" wx:if="{{story && story.documentTabs.length > 0 && activeDocumentKey === 'summary'}}" bindtap="handleEnterFullReport">
    <view class="detail-full-report-pin__inner">
      <text class="detail-full-report-pin__label">查看完整报告</text>
      <text class="detail-full-report-pin__arrow">›</text>
    </view>
  </view>

  <view class="detail-bottom-tabs" wx:if="{{story && story.documentTabs.length > 1 && activeDocumentKey !== 'summary'}}">
    <view
      class="detail-bottom-tabs__item {{item.key === activeDocumentKey ? 'detail-bottom-tabs__item--active' : ''}}"
      wx:for="{{story.documentTabs}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="handleDocumentTabTap"
    >
      {{item.label}}
    </view>
  </view>
</view>

