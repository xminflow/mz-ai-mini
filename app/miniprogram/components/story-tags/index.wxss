.story-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.story-tags__item {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #fbf6ee 0%, #fffdfa 100%);
  border: 1rpx solid rgba(162, 116, 71, 0.18);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9),
    0 10rpx 20rpx rgba(146, 101, 58, 0.08);
}

.story-tags__dot {
  width: 10rpx;
  height: 10rpx;
  flex: 0 0 auto;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #d59854 0%, #8c5a2b 100%);
  box-shadow: 0 0 0 4rpx rgba(214, 152, 84, 0.12);
}

.story-tags__text {
  color: #6f4a2b;
  font-weight: 500;
  letter-spacing: 0.4rpx;
  line-height: 1.4;
}

.story-tags--sm {
  gap: 10rpx;
}

.story-tags--sm .story-tags__item {
  gap: 8rpx;
  padding: 8rpx 14rpx;
}

.story-tags--sm .story-tags__dot {
  width: 8rpx;
  height: 8rpx;
  box-shadow: 0 0 0 3rpx rgba(214, 152, 84, 0.12);
}

.story-tags--sm .story-tags__text {
  font-size: 19rpx;
}

.story-tags--md .story-tags__text {
  font-size: 23rpx;
}
