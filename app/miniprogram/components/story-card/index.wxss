.story-card {
  background: #FFFFFF;
  border: 1rpx solid rgba(11, 11, 11, 0.06);
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow:
    0 10rpx 20rpx rgba(11, 11, 11, 0.04),
    0 24rpx 44rpx rgba(11, 11, 11, 0.08);
}

.story-card__cover {
  width: 100%;
  height: 228rpx;
  display: block;
  background: #E5E7EB;
}

.story-card__body {
  padding: 20rpx 18rpx 22rpx;
}

.story-card__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.story-card__meta-item {
  font-size: 17rpx;
  line-height: 1.5;
  color: #6B7280;
}

.story-card__title {
  color: #1F1F1F;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 500;
  letter-spacing: 0.4rpx;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.story-card__summary {
  margin-top: 12rpx;
  color: #6B7280;
  font-size: 22rpx;
  line-height: 1.8;
  font-weight: 400;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
}

.story-card__tags {
  margin-top: 14rpx;
}

.story-card__footer {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
  margin-top: 16rpx;
}

.story-card__result {
  width: 100%;
  box-sizing: border-box;
  color: #6B7280;
  font-size: 20rpx;
  line-height: 1.7;
  font-weight: 400;
  padding: 12rpx 14rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(11, 11, 11, 0.08);
  border-radius: 8rpx;
}
